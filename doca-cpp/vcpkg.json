{
    "name": "doca-cpp",
    "version": "0.1.3",
    "description": "C++ Adapter For NVIDIA DOCA Framework. Requires NVIDIA DOCA SDK installed on the system (https://developer.nvidia.com/networking/doca).",
    "homepage": "https://github.com/fogesque/doca-cpp",
    "license": "MIT",
    "supports": "linux",
    "dependencies": [
        {
            "name": "vcpkg-cmake",
            "host": true
        },
        {
            "name": "vcpkg-cmake-config",
            "host": true
        },
        {
            "name": "asio"
        },
        {
            "name": "errors"
        },
        {
            "name": "kvalog"
        }
    ],
    "features": {
        "testing": {
            "description": "Build tests",
            "dependencies": [
                "gtest"
            ]
        },
        "samples": {
            "description": "Build examples",
            "dependencies": [
                "yaml-cpp"
            ]
        }
    }
}