{
    "name": "inflare",
    "version": "0.2.1",
    "port-version": 1,
    "description": "RDMA Streaming C++ Library. Requires NVIDIA DOCA SDK installed on the system (https://developer.nvidia.com/networking/doca).",
    "homepage": "https://github.com/fogesque/inflare",
    "license": "MIT",
    "supports": "linux",
    "dependencies": [
        {
            "name": "vcpkg-cmake",
            "host": true
        },
        {
            "name": "vcpkg-cmake-config",
            "host": true
        },
        {
            "name": "asio"
        },
        {
            "name": "errors"
        },
        {
            "name": "kvalog"
        }
    ],
    "features": {
        "gpunetio": {
            "description": "Build GPU RDMA streaming module (requires CUDA 13+ and DOCA GPUNetIO)"
        }
    }
}