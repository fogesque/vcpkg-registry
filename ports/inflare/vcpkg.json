{
    "name": "inflare",
    "version": "0.3.3",
    "port-version": 0,
    "description": "RDMA Streaming C++ Library",
    "homepage": "https://github.com/fogesque/inflare",
    "license": "MIT",
    "supports": "linux",
    "dependencies": [
        {
            "name": "vcpkg-cmake",
            "host": true
        },
        {
            "name": "vcpkg-cmake-config",
            "host": true
        },
        {
            "name": "asio"
        },
        {
            "name": "errors"
        }
    ],
    "features": {
        "gpunetio": {
            "description": "Build CUDA/GPU RDMA streaming support (requires CUDA Toolkit and GPUDirect-capable platform)"
        },
        "logging": {
            "description": "Enable Inflare logging macros and public logging API",
            "dependencies": [
                "kvalog"
            ]
        }
    }
}